#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

function readStdin() {
  return new Promise((resolve) => {
    let data = '';
    process.stdin.setEncoding('utf8');
    process.stdin.on('data', (chunk) => {
      data += chunk;
    });
    process.stdin.on('end', () => resolve(data.trim()));
  });
}

function write(file, content) {
  const target = path.join(process.cwd(), file);
  fs.mkdirSync(path.dirname(target), { recursive: true });
  fs.writeFileSync(target, content);
  console.log(`[newbolt-agent] wrote ${file}`);
}

function musicPlayerFiles(prompt) {
  const title = /qq|music|player|song|audio/i.test(prompt) ? 'QQ Music Player MVP' : 'NewBolt Generated App';
  return {
    'index.html': `<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>${title}</title>
  <link rel="stylesheet" href="./styles.css" />
</head>
<body>
  <main class="player-shell">
    <section class="hero">
      <div>
        <p class="eyebrow">AI generated workspace</p>
        <h1>${title}</h1>
        <p class="summary">A deployable static app created inside the Docker sandbox.</p>
      </div>
      <button id="playButton" class="primary">Play</button>
    </section>
    <section class="now-playing">
      <div class="cover">N</div>
      <div class="track">
        <span id="status">Ready</span>
        <strong>Midnight Build</strong>
        <small>NewBolt Studio</small>
      </div>
    </section>
    <section class="playlist" id="playlist"></section>
  </main>
  <script src="./app.js"></script>
</body>
</html>
`,
    'styles.css': `:root {
  color-scheme: light;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: #f6f7f8;
  color: #171a1f;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 32px;
}

.player-shell {
  width: min(920px, 100%);
  display: grid;
  gap: 18px;
}

.hero,
.now-playing,
.playlist {
  background: #ffffff;
  border: 1px solid #e1e4e8;
  border-radius: 8px;
  padding: 22px;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.eyebrow {
  margin: 0 0 8px;
  color: #6d7682;
  font-size: 13px;
  text-transform: uppercase;
}

h1 {
  margin: 0;
  font-size: clamp(28px, 4vw, 48px);
  letter-spacing: 0;
}

.summary {
  margin: 10px 0 0;
  color: #555e69;
}

.primary {
  border: 0;
  border-radius: 8px;
  background: #171a1f;
  color: #ffffff;
  min-width: 112px;
  height: 44px;
  font-weight: 700;
  cursor: pointer;
}

.now-playing {
  display: flex;
  align-items: center;
  gap: 16px;
}

.cover {
  width: 86px;
  aspect-ratio: 1;
  border-radius: 8px;
  display: grid;
  place-items: center;
  background: #e7f3ee;
  color: #126349;
  font-size: 34px;
  font-weight: 800;
}

.track {
  display: grid;
  gap: 4px;
}

.track span,
.track small {
  color: #6d7682;
}

.playlist {
  display: grid;
  gap: 10px;
}

.song {
  display: grid;
  grid-template-columns: 32px 1fr auto;
  align-items: center;
  gap: 12px;
  min-height: 44px;
  border-bottom: 1px solid #edf0f2;
}

.song:last-child {
  border-bottom: 0;
}

@media (max-width: 640px) {
  body {
    padding: 18px;
  }

  .hero {
    align-items: stretch;
    flex-direction: column;
  }
}
`,
    'app.js': `const songs = [
  ['01', 'Midnight Build', '03:42'],
  ['02', 'Preview Window', '04:08'],
  ['03', 'Deploy Button', '02:57']
];

const playlist = document.querySelector('#playlist');
const status = document.querySelector('#status');
const playButton = document.querySelector('#playButton');

playlist.innerHTML = songs.map((song) => {
  return '<div class="song"><span>' + song[0] + '</span><strong>' + song[1] + '</strong><small>' + song[2] + '</small></div>';
}).join('');

let playing = false;
playButton.addEventListener('click', () => {
  playing = !playing;
  playButton.textContent = playing ? 'Pause' : 'Play';
  status.textContent = playing ? 'Playing' : 'Ready';
});
`,
    'README.md': `# ${title}

Generated by the NewBolt sandbox fallback agent.

Open the preview panel or deploy a snapshot from the workbench.
`
  };
}

async function main() {
  const prompt = await readStdin();
  console.log('[newbolt-agent] Claude Code was not found in this sandbox.');
  console.log('[newbolt-agent] Using deterministic fallback generation.');
  console.log(`[newbolt-agent] prompt: ${prompt || '(empty)'}`);

  const files = musicPlayerFiles(prompt);
  for (const [file, content] of Object.entries(files)) {
    write(file, content);
  }

  fs.mkdirSync(path.join(process.cwd(), '.newbolt'), { recursive: true });
  fs.writeFileSync(path.join(process.cwd(), '.newbolt', 'last-agent-summary.txt'), 'Fallback agent generated a static app.');

  console.log('[newbolt-agent] done');
}

main().catch((error) => {
  console.error(error.stack || String(error));
  process.exit(1);
});
